# Model credentials — pick ONE (precedence: API key > subscription token > mock):
#  • ANTHROPIC_API_KEY: real API-billed agent via agentd's model proxy.
#  • CLAUDE_CODE_OAUTH_TOKEN: Claude Code SUBSCRIPTION billing — run
#    `claude setup-token` on the host and paste the sk-ant-oat01-… token here,
#    leaving ANTHROPIC_API_KEY blank. Sessions then call api.anthropic.com
#    directly. Note: Anthropic's terms restrict subscription OAuth for headless
#    automation (docs/AGENTS_RESEARCH.md) — personal-use opt-in.
#  • Both blank: deterministic offline mock model.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# HS256 secret agentd uses to VERIFY JWTs that apps mint (and that /dev/token signs).
# Leave blank for dev-open mode (no auth) — fine for a local demo only.
# REQUIRED (and worth changing) when a login mode below is enabled.
AGENTKIT_JWT_SECRET=dev-secret

# ── Login + projects (optional — leave unset for the zero-login demo) ──────────
# Google login: create an OAuth 2.0 Client ID (Web application) in the Google
# Cloud console with authorized JavaScript origin http://localhost:8080.
# GOOGLE_CLIENT_ID=1234567890-abc.apps.googleusercontent.com
#
# Hard-coded email → projects map (a project is a kebab-case namespace over
# sessions). Inline JSON, or AGENTKIT_PROJECT_MAP_FILE=/path/to/projects.json.
# A "*" in a user's list is a wildcard (dev): every project in the map, plus
# the ability to create new projects from the UI.
# AGENTKIT_PROJECT_MAP={"kaiyadavenport@gmail.com":["*"]}
#
# Fixed password login (TEST/DEV only — grants every project in the map).
# Used by e2e/run-stack-e2e.sh; handy for local dev without Google.
# AGENTKIT_TEST_LOGIN=test@example.com:orange-e2e

# Sandbox image the Runner launches per session. Override to your own app image.
BASE_IMAGE=agentkit-sandbox:dev

# Host port the browser opens.
WEB_PORT=8080

# ── Storage backends (default = local: filesystem blobs + blob-archive snapshots) ──
# Leave these unset for the offline local stack. Set them to run on Google Cloud.
#
# Blobs (artifact bytes + blob-archive snapshots) → Google Cloud Storage:
#   AGENTKIT_BLOB_BACKEND=gcs
#   GCS_BUCKET=webkit-servers-agent-orange
#   GCS_PREFIX=                       # optional key prefix within the bucket
#
# Session-snapshot images → Google Artifact Registry (instead of blob-archive):
#   AGENTKIT_REGISTRY_BACKEND=ociregistry
#   AGENTKIT_REGISTRY_AUTH=gcp        # gcp (ADC token) | basic
#   GCP_REGION=europe-west1
#   GCP_PROJECT=webkit-servers
#   GCP_AR_REPO=agent-orange          # → europe-west1-docker.pkg.dev/webkit-servers/agent-orange
#   # …or set OCI_REGISTRY=<full-url> directly; for basic auth set OCI_USERNAME/OCI_PASSWORD.
#
# GCP auth uses Application Default Credentials. For the containerised stack the
# agentd container needs ADC — mount a service-account key and point
# GOOGLE_APPLICATION_CREDENTIALS at it (see docker-compose.yml comments).
# GOOGLE_APPLICATION_CREDENTIALS=/gcp/key.json
