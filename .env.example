# Set a real key for a real agent; leave blank for the zero-config mock model.
ANTHROPIC_API_KEY=

# HS256 secret agentd uses to VERIFY JWTs that apps mint (and that /dev/token signs).
# Leave blank for dev-open mode (no auth) — fine for a local demo only.
AGENTKIT_JWT_SECRET=dev-secret

# Sandbox image the Runner launches per session. Override to your own app image.
BASE_IMAGE=agentkit-sandbox:dev

# Host port the browser opens.
WEB_PORT=8080
