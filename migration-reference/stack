function generate_types_go() {
  local package_name="${1-carbon}"
  local swagger_file="swagger.${package_name}.json"

  # Use patched swagger file if it exists
  if [ -f "swagger.${package_name}.patched.json" ]; then
    swagger_file="swagger.${package_name}.patched.json"
  fi

  echo "generating new go types for ${package_name} from ${swagger_file}"
  docker run --rm \
  -v "$PWD":/local \
  openapitools/openapi-generator-cli:latest \
    generate \
    -i "/local/${swagger_file}" \
    -g go \
    -o "/local/goapi/pkg/types/${package_name}" \
    --global-property models,supportingFiles,modelDocs=false,apiDocs=false,apiTests=false,modelTests=false \
    --additional-properties enumClassPrefix=true,packageName=$package_name,withGoMod=false
}

