    source .env
    set +a
  fi

  local git_hash
  git_hash=$(git rev-parse --short=8 HEAD)

  echo "Building images with tag: $git_hash"

  docker build \
    --platform linux/amd64 \
    --build-arg APP_VERSION="$git_hash" \
    -t platinum-goapi:$git_hash \
    -t platinumimages.azurecr.io/platinum-goapi:$git_hash \
    --target api-final-build \
    -f Dockerfile .

  docker build \
    --platform linux/amd64 \
    --build-arg APP_VERSION="$git_hash" \
    -t platinum-goworker:$git_hash \
    -t platinumimages.azurecr.io/platinum-goworker:$git_hash \
    --target worker-final-build \
    -f Dockerfile .

  docker build \
    --platform linux/amd64 \
    --build-arg VITE_SENTRY_DSN="${VITE_SENTRY_DSN:-}" \
    --build-arg VITE_SENTRY_ENVIRONMENT="${SENTRY_ENVIRONMENT:-production}" \
    -t platinum-frontend:$git_hash \
    -t platinumimages.azurecr.io/platinum-frontend:$git_hash \
    --target frontend-final-build \
    -f Dockerfile .

  docker build \
    --platform linux/amd64 \
    -t platinum-carbon:$git_hash \
    -t platinumimages.azurecr.io/platinum-carbon:$git_hash \
    --target carbon-final-build \
    -f Dockerfile .

  docker build \
    --platform linux/amd64 \
    -t platinum-dind:$git_hash \
    -t platinumimages.azurecr.io/platinum-dind:$git_hash \
    -f dind/Dockerfile.prod .

  echo "Built images:"
  echo "  platinum-goapi:$git_hash"
  echo "  platinum-goworker:$git_hash"
  echo "  platinum-frontend:$git_hash"
  echo "  platinum-carbon:$git_hash"
  echo "  platinum-dind:$git_hash"
}

function push_images() {
  local git_hash
  git_hash=$(git rev-parse --short=8 HEAD)

  # Push side: host docker login to ACR with the admin creds (reuses acr-login,
  # which sources AGENT_V2_REGISTRY_USERNAME/PASSWORD from .env). The server pulls
  # with the same creds. ACR dedups layers, so unchanged images push near-instantly.
  acr-login

  echo "Pushing images to platinumimages.azurecr.io (tag: $git_hash)..."
  for name in goapi goworker frontend carbon dind; do
    local ref="platinumimages.azurecr.io/platinum-${name}:${git_hash}"
    echo "  pushing $ref"
    docker push "$ref"
  done
  echo "All images pushed to ACR"
}

# release — coordinate a full production/staging release in the correct order so
# the agent sandbox images and the app images are deployed consistently.
#
# Why this exists: `deploy` ships the code as-is, but the agent sandbox images
# live in a FROM-chain that must first be built + pushed to ACR; that push
# records each image's content digest back into installation.json + the embedded
# manifest.json. Those recorded digests are a source change, so they must be
# committed *before* the app images are built (goapi embeds the manifest at build
# time). The digest is a content hash of the image — independent of this commit —
# so it converges in exactly one extra commit, no iteration.
#
#   1. assert: on main, clean tree, fast-forwarded to origin
#   2. build + push sandbox images to ACR (records digests)
#   3. commit + push the recorded digests (if any changed)
#   4. deploy the app images at the now-clean HEAD (guarded by installcheck)
function release() {
  local environment="${1:-}"
  if [[ "$environment" != "production" && "$environment" != "staging" ]]; then
    echo "Usage: ./stack release [production|staging]" >&2
    exit 1
  fi

  # Step 1: preconditions
  local branch; branch=$(git rev-parse --abbrev-ref HEAD)
  if [[ "$branch" != "main" ]]; then
    echo "ERROR: release must run from 'main' (currently on '$branch')" >&2
    exit 1
  fi
  if [[ -n "$(git status --porcelain)" ]]; then
    echo "ERROR: uncommitted changes — commit or stash before releasing" >&2
    git status --short
    exit 1
  fi
  echo "=== Step 1/4: Fast-forwarding main to origin ==="
  git pull --ff-only

  # Step 2: build + push the sandbox image chain to ACR, recording digests into
  # installations/*/installation.json and goapi/pkg/installations/manifest.json.
  echo ""
  echo "=== Step 2/4: Building + pushing sandbox images to ACR ==="
  rebuild sandbox all --acr

  # Step 3: absorb the recorded digests so the goapi build embeds them. Commit
  # LOCALLY only — the push is deferred to step 5 (after a successful deploy) so
  # that a cancelled/failed deploy leaves only a recoverable local commit on this
  # machine and never an orphaned digest-pin commit on origin/main. The server
  # never pulls git (it deploys by IMAGE_TAG), so the push order is pure hygiene.
  local committed=""
  echo ""
  echo "=== Step 3/5: Committing recorded sandbox digests (local) ==="
  if [[ -n "$(git status --porcelain installations goapi/pkg/installations/manifest.json)" ]]; then
    git add installations/*/installation.json goapi/pkg/installations/manifest.json
    git commit -m "build: pin sandbox installation image digests for ${environment} release"
    committed=1
    echo "Committed new sandbox digests locally (push deferred until after deploy)."
  else
    echo "Sandbox digests unchanged — nothing to commit."
  fi

  # Step 4: deploy the app images at the (clean) HEAD. If the operator cancels at
  # deploy's confirmation, the script exits here with the local commit intact and
  # nothing pushed.
  echo ""
  echo "=== Step 4/5: Deploying app images ==="
  deploy "$environment"

  # Step 5: deploy succeeded — now publish the digest commit.
  echo ""
  echo "=== Step 5/5: Pushing release commit ==="
  if [[ -n "$committed" ]]; then
    git push
    echo "Pushed release commit to origin."
  else
    echo "Nothing new to push."
  fi
}

function deploy() {
  local environment="${1:-}"

  # Validate environment argument
  if [[ -z "$environment" ]]; then
    echo "Error: Environment argument required (production or staging)"
    echo "Usage: ./stack deploy [production|staging]"
    exit 1
  fi

  # Set environment variables based on environment
  local env_name router_port server_base_url carbon_url licensing_url locked_down_emails

  if [[ "$environment" == "production" ]]; then
    env_name="production"
    router_port="8091"
    server_base_url="https://app.bayesprice.ai"
    carbon_url="http://carbon:8090/"
    licensing_url="https://bayesprice.azurewebsites.net/licensingprod/"
    locked_down_emails=""
    chatops_group_id=""  # inherits from .env (WhatsApp active in production)
  elif [[ "$environment" == "staging" ]]; then
    env_name="staging"
    router_port="8092"
    server_base_url="https://dev.bayesprice.ai"
    carbon_url="http://carbon:8090/"
    licensing_url="https://bayesprice.azurewebsites.net/licensingtest/"
    locked_down_emails="kaiyadavenport@gmail.com,@bayesprice.com"
    chatops_group_id="disabled"  # override to disable WhatsApp in staging
  else
    echo "Error: Invalid environment '$environment'"
    echo "Valid environments: production, staging"
    exit 1
  fi

  # Get git hash
  local git_hash
  git_hash=$(git rev-parse --short=8 HEAD)

  # Check for uncommitted changes locally
  if [[ -n "$(git status --porcelain)" ]]; then
    echo "Error: Uncommitted changes detected locally"
    git status --short
    exit 1
  fi

  # Guard: every agent installation must resolve to a launchable image in
  # production. In ACR registry mode that requires a committed image digest in
  # the embedded manifest — without it, the app deploys fine but agent sessions
  # resolve to nothing. Check the committed manifest before building so we fail
  # fast (and before prompting the user to confirm).
  local acr_url
  acr_url="$( set -a; [[ -f "$DIR/.env" ]] && source "$DIR/.env"; set +a; echo "${AGENT_V2_REGISTRY_URL:-platinumimages.azurecr.io}" )"
  if installations_is_local_registry "$acr_url"; then acr_url="platinumimages.azurecr.io"; fi
  # The guard reuses the goapi resolution logic via `go run`. The build machine
  # has Go (it compiles goapi); a Go-less deploy host can't run it, so skip with a
  # loud warning rather than blocking — `release` always pins on a Go-equipped
  # machine before this point.
  if command -v go >/dev/null 2>&1; then
    echo "Verifying agent installation images are pinned for $acr_url..."
    if ! ( cd "$DIR" && go run ./goapi/cmd/installcheck -registry "$acr_url" ); then
      echo "ERROR: agent installation images are not pinned for $acr_url." >&2
      echo "       Use './stack release $environment' — it builds + pushes the sandbox" >&2
      echo "       images to ACR, commits their digests, then deploys. Aborting." >&2
      exit 1
    fi
  else
    echo "WARNING: 'go' not found — skipping installation-image pin check." >&2
    echo "         Ensure './stack release' was run on a Go-equipped build machine." >&2
  fi

  # Confirm with user
  echo "================================================"
  echo "DEPLOYMENT CONFIRMATION"
  echo "================================================"
  echo "Environment:        $env_name"
  echo "Image Tag:          $git_hash"
  echo "Router Port:        $router_port"
  echo "Server Base URL:    $server_base_url"
  echo "Carbon URL:         $carbon_url"
  echo "Licensing URL:      $licensing_url"
  echo "Locked Down Emails: $locked_down_emails"
  echo "Remote Host:        $DEPLOY_HOST"
  echo "================================================"
  read -p "Proceed with deployment? [y/N] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Deployment cancelled"
    exit 0
  fi

  echo "Starting deployment to $env_name..."

  # Step 1: Build images locally
  echo ""
  echo "=== Step 1/3: Building images locally ==="
  build_images

  # Step 2: Push images to ACR
  echo ""
  echo "=== Step 2/3: Pushing images to ACR ==="
  push_images

  # Step 3: Deploy on server
  echo ""
  echo "=== Step 3/3: Deploying on server ==="
  if is_deploy_host; then
    (
      set -euo pipefail

      # Load ACR creds for the pull, fail fast if absent (clearer than a 401)
      set -a; source .env; set +a
      if [[ -z "${AGENT_V2_REGISTRY_USERNAME:-}" || -z "${AGENT_V2_REGISTRY_PASSWORD:-}" ]]; then
        echo "ERROR: AGENT_V2_REGISTRY_USERNAME/PASSWORD missing from .env — cannot pull from ACR" >&2
        exit 1
      fi
      echo "$AGENT_V2_REGISTRY_PASSWORD" | docker login platinumimages.azurecr.io \
        -u "$AGENT_V2_REGISTRY_USERNAME" --password-stdin

      echo "Starting containers with IMAGE_TAG=$git_hash..."
      export ENV=$env_name
      export IMAGE_TAG=$git_hash
      export ACR_PREFIX=platinumimages.azurecr.io/
      export ROUTER_PORT=$router_port
      export SERVER_BASE_URL=$server_base_url
      export PLATINUM_CARBON_URL=$carbon_url
      export PLATINUM_LICENSING_URL=$licensing_url
      export PLATINUM_LOCKED_DOWN_EMAILS=$locked_down_emails
      export PLATINUM_USE_STATELESS_TABLE_LOADER=$USE_FAST_CARBON
      export SENTRY_ENVIRONMENT=$env_name
      # Only enable WhatsApp notifications in production
      if [[ "$chatops_group_id" == "disabled" ]]; then
        export WHATSAPP_GROUP_ID=""
      else
        export COMPOSE_PROFILES=production
      fi

      docker compose -p $env_name down
      docker volume create ${env_name}-dind-data 2>/dev/null || true
      docker volume create ${env_name}-waha-data 2>/dev/null || true
      docker compose -p $env_name pull
      docker compose -p $env_name up -d

      # Start WAHA WhatsApp session (if configured)
      if [[ -n "${WHATSAPP_GROUP_ID:-}" ]]; then
        echo "Starting WAHA WhatsApp session..."
        for i in $(seq 1 15); do
          if docker exec ${env_name}-waha wget -qO- http://localhost:3000/health > /dev/null 2>&1; then
            docker exec ${env_name}-waha wget -qO- \
              --post-data='{"name":"default"}' \
              --header='Content-Type: application/json' \
              --header="X-Api-Key: ${SYSTEM_SECRET:-secret}" \
              http://localhost:3000/api/sessions/start 2>/dev/null || true
            echo "WAHA session start requested"
            break
          fi
          sleep 2
        done
      fi

      echo "Deployment to $env_name completed!"
    )
  else
    ssh $DEPLOY_HOST <<EOF
set -euo pipefail

cd Platinum

# Load ACR creds for the pull, fail fast if absent (clearer than a 401)
set -a; source .env; set +a
if [[ -z "\${AGENT_V2_REGISTRY_USERNAME:-}" || -z "\${AGENT_V2_REGISTRY_PASSWORD:-}" ]]; then
  echo "ERROR: AGENT_V2_REGISTRY_USERNAME/PASSWORD missing from server .env — cannot pull from ACR" >&2
  exit 1
fi
echo "\$AGENT_V2_REGISTRY_PASSWORD" | docker login platinumimages.azurecr.io \
  -u "\$AGENT_V2_REGISTRY_USERNAME" --password-stdin

echo "Starting containers with IMAGE_TAG=$git_hash..."
export ENV=$env_name
export IMAGE_TAG=$git_hash
export ACR_PREFIX=platinumimages.azurecr.io/
export ROUTER_PORT=$router_port
export SERVER_BASE_URL=$server_base_url
export PLATINUM_CARBON_URL=$carbon_url
export PLATINUM_LICENSING_URL=$licensing_url
export PLATINUM_LOCKED_DOWN_EMAILS=$locked_down_emails
export PLATINUM_USE_STATELESS_TABLE_LOADER=$USE_FAST_CARBON
export SENTRY_ENVIRONMENT=$env_name
# Only enable WhatsApp notifications in production
if [[ "$chatops_group_id" == "disabled" ]]; then
  export WHATSAPP_GROUP_ID=""
else
  export COMPOSE_PROFILES=production
fi

docker compose -p $env_name down
docker volume create ${env_name}-dind-data 2>/dev/null || true
docker volume create ${env_name}-waha-data 2>/dev/null || true
docker compose -p $env_name pull
docker compose -p $env_name up -d

# Start WAHA WhatsApp session (if configured)
if [[ -n "\${WHATSAPP_GROUP_ID:-}" ]]; then
  echo "Starting WAHA WhatsApp session..."
  for i in \$(seq 1 15); do
    if docker exec ${env_name}-waha wget -qO- http://localhost:3000/health > /dev/null 2>&1; then
      docker exec ${env_name}-waha wget -qO- \
        --post-data='{"name":"default"}' \
        --header='Content-Type: application/json' \
        --header="X-Api-Key: \${SYSTEM_SECRET:-secret}" \
        http://localhost:3000/api/sessions/start 2>/dev/null || true
      echo "WAHA session start requested"
      break
    fi
    sleep 2
  done
fi

echo "Deployment to $env_name completed!"
EOF
  fi

  local exit_code=$?
  if [[ $exit_code -eq 0 ]]; then
    echo "================================================"
    echo "Deployment to $env_name completed successfully!"
    echo "Image tag: $git_hash"
    echo "================================================"
  else
    echo "================================================"
    echo "Deployment to $env_name failed with exit code $exit_code"
    echo "================================================"
    exit $exit_code
  fi
}

function print_versions() {
  echo "Fetching deployed versions..."
  echo ""

  # Get production version from remote
  local prod_hash
  prod_hash=$(ssh $DEPLOY_HOST "docker ps --filter 'name=production-goapi' --format '{{.Image}}' 2>/dev/null | head -1 | cut -d':' -f2" 2>/dev/null || echo "")

  # Get staging version from remote
  local staging_hash
  staging_hash=$(ssh $DEPLOY_HOST "docker ps --filter 'name=staging-goapi' --format '{{.Image}}' 2>/dev/null | head -1 | cut -d':' -f2" 2>/dev/null || echo "")

  # Get local version
  local local_hash
  local_hash=$(git rev-parse --short=8 HEAD)

  # Print header
  printf "%-12s  %-10s  %-40s  %s\n" "Environment" "Short" "Full Hash" "Commit Message"
  printf "%.0s─" {1..100}
  echo ""

  # Print production
  if [[ -n "$prod_hash" ]]; then
    local prod_full prod_msg
    prod_full=$(git rev-parse "$prod_hash" 2>/dev/null || echo "unknown")
    prod_msg=$(git log -1 --format='%s' "$prod_hash" 2>/dev/null | head -c 50 || echo "")
    printf "%-12s  %-10s  %-40s  %s\n" "Production" "$prod_hash" "$prod_full" "$prod_msg"
  else
    printf "%-12s  %-10s  %-40s  %s\n" "Production" "-" "not running" ""
  fi

  # Print staging
  if [[ -n "$staging_hash" ]]; then
    local staging_full staging_msg
    staging_full=$(git rev-parse "$staging_hash" 2>/dev/null || echo "unknown")
    staging_msg=$(git log -1 --format='%s' "$staging_hash" 2>/dev/null | head -c 50 || echo "")
    printf "%-12s  %-10s  %-40s  %s\n" "Staging" "$staging_hash" "$staging_full" "$staging_msg"
  else
    printf "%-12s  %-10s  %-40s  %s\n" "Staging" "-" "not running" ""
  fi

  # Print local
  local local_full local_msg
  local_full=$(git rev-parse HEAD)
  local_msg=$(git log -1 --format='%s' HEAD | head -c 50)
  printf "%-12s  %-10s  %-40s  %s\n" "Local" "$local_hash" "$local_full" "$local_msg"

  echo ""

  # Show comparison hints if versions differ
  if [[ -n "$prod_hash" && "$prod_hash" != "$local_hash" ]]; then
    echo "To compare local vs production:"
    echo "  git log --oneline ${prod_hash}..HEAD"
    echo "  git diff ${prod_hash}..HEAD"
  fi
  if [[ -n "$staging_hash" && "$staging_hash" != "$local_hash" ]]; then
    echo "To compare local vs staging:"
    echo "  git log --oneline ${staging_hash}..HEAD"
    echo "  git diff ${staging_hash}..HEAD"
  fi
}

