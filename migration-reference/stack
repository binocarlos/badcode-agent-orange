function sync_db() {
  local environment="${1:-}"

  if [[ -z "$environment" ]]; then
    echo "Error: Environment argument required (production or staging)"
    echo "Usage: ./stack sync_db [production|staging]"
    exit 1
  fi

  if [[ "$environment" != "production" && "$environment" != "staging" ]]; then
    echo "Error: Invalid environment '$environment'"
    echo "Valid environments: production, staging"
    exit 1
  fi

  local remote_container="platinum-${environment}-postgres"

  echo "================================================"
  echo "DATABASE SYNC: $environment -> local"
  echo "================================================"
  echo "Remote host:      $DEPLOY_HOST"
  echo "Remote container: $remote_container"
  echo "Local container:  postgres"
  echo ""
  echo "WARNING: This will REPLACE your local database!"
  echo "================================================"
  read -p "Proceed? [y/N] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Sync cancelled"
    exit 0
  fi

  echo ""
  echo "=== Step 1/2: Dumping remote database ==="
  echo "Running pg_dump on $remote_container..."

  echo ""
  echo "=== Step 2/2: Restoring to local ==="
  # Pipe pg_dump from remote directly into local psql
  # --clean adds DROP statements, --if-exists prevents errors
  # --no-owner and --no-acl skip ownership/permissions (different users locally)
  ssh $DEPLOY_HOST "docker exec $remote_container pg_dump --user postgres --clean --if-exists --no-owner --no-acl postgres" \
    | devcompose exec -T postgres psql --user postgres postgres

  echo ""
  echo "================================================"
  echo "Database sync complete!"
  echo "Restart your local services to run migrations."
