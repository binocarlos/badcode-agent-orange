function patch_swagger_carbon() {
  echo "patching swagger.carbon.json for known upstream issues"
  # Fix malformed $ref for self-referential types (e.g. GenNode.Children -> GenNode).
  # .NET 9 OpenAPI generates broken refs like "#/components/schemas/#/properties/variableTree/items"
  # instead of "#/components/schemas/GenNode". For each schema, walk its tree and replace any
  # malformed $ref with a proper self-reference to the owning schema.
  python3 -c '
import json, sys

with open("swagger.carbon.json") as f:
    spec = json.load(f)

schemas = spec.get("components", {}).get("schemas", {})

def fix_refs(obj, owner_name):
    if isinstance(obj, dict):
        if "$ref" in obj and obj["$ref"].startswith("#/components/schemas/#/"):
            obj["$ref"] = f"#/components/schemas/{owner_name}"
        for v in obj.values():
            fix_refs(v, owner_name)
    elif isinstance(obj, list):
        for item in obj:
            fix_refs(item, owner_name)

for name, schema in schemas.items():
    fix_refs(schema, name)

with open("swagger.carbon.patched.json", "w") as f:
    json.dump(spec, f, indent=2)
  '
}

function simplify_carbon_models() {
  echo "simplifying generated Go model files (stripping boilerplate, depointerizing primitives)"
  local dir="goapi/pkg/types/carbon"

  for f in "$dir"/model_*.go; do
    [ -f "$f" ] || continue
    local base
    base=$(basename "$f")

    # Skip enum files — they define "type Foo string" not structs with pointer fields
    if grep -q '^type [A-Za-z_]* string$' "$f" 2>/dev/null; then
      echo "  skip enum: $base"
      continue
    fi

    echo "  simplify: $base"

    # Pre-scan: check if time.Time is used anywhere in the file
    local has_time=0
    if grep -q 'time\.Time' "$f" 2>/dev/null; then
      has_time=1
    fi

    # Use awk to extract package + struct definitions only
    awk -v need_time="$has_time" '
    BEGIN { in_struct=0; printed_header=0 }

    # Print package line
    /^package / {
      pkg=$0
      next
    }

    # Detect struct opening
    /^type [A-Za-z_0-9]+ struct \{/ {
      if (!printed_header) {
        print pkg
        print ""
        if (need_time) {
          print "import \"time\""
          print ""
        }
        printed_header=1
      }
      in_struct=1
      print $0
      next
    }

    # Inside struct, print fields until closing brace
    in_struct==1 {
      print $0
      if (/^\}/) {
        in_struct=0
        print ""
      }
      next
    }
    ' "$f" > "$f.tmp"

    # If the file produced no output (no structs found), skip it
    if [ ! -s "$f.tmp" ]; then
      rm -f "$f.tmp"
      continue
    fi

    # Replace pointer primitives with plain types.
    # Note: float32/float64 are NOT depointerized because 0.0 can be
    # a meaningful value distinct from "not set" (e.g. PlatinumCell.Freq).
    sed -i \
      -e 's/\*string/string/g' \
      -e 's/\*bool/bool/g' \
      -e 's/\*int32/int32/g' \
      -e 's/\*int64/int64/g' \
      "$f.tmp"

    # Note: omitempty stripping is no longer needed here. The C# schema
    # transformer in Program.cs marks value-type properties as required,
    # so the Go generator does not add omitempty to them.

    mv "$f.tmp" "$f"
  done

  # Fix self-referential GenNode types: the generator may produce "Items" as the
  # child type when the $ref is malformed. Replace with the correct parent type.
  for f in "$dir"/model_gen_node*.go; do
    [ -f "$f" ] || continue
    # Extract the struct name (e.g. GenNode, GenNode2, GenNode3)
    local struct_name
    struct_name=$(grep -oP '^type \K[A-Za-z0-9]+(?= struct)' "$f" | head -1)
    if [ -n "$struct_name" ] && grep -q '\bItems\b' "$f"; then
      echo "  fix self-ref: $struct_name in $(basename "$f")"
      sed -i "s/\bItems\b/$struct_name/g" "$f"
    fi
  done

  # Remove files that only had boilerplate (no structs) — the generator
  # creates MappedNullable interface checks, Nullable wrappers etc.
  rm -f "$dir"/model_*.go.tmp 2>/dev/null || true

  # Fix naming mismatches from the OpenAPI generator before deleting duplicate files
  echo "  fixing naming: PlatinumProperties2 → PlatinumProperties"
  for f in "$dir"/model_*.go; do
    [ -f "$f" ] || continue
    sed -i \
      -e 's/PlatinumProperties2/PlatinumProperties/g' \
      "$f"
  done

  # Remove generated types that Go never uses (Go has wrapper types in stateless.go
  # or the types are duplicates/dead code from swagger)
  echo "  removing unused generated model files"
  rm -f "$dir"/model_run_spec_request.go \
       "$dir"/model_run_spec_response.go \
       "$dir"/model_var_tree_request.go \
       "$dir"/model_var_tree_response.go \
       "$dir"/model_axis_nodes_to_syntax_request.go \
       "$dir"/model_axis_syntax_to_nodes_request.go \
       "$dir"/model_gen_node2.go \
       "$dir"/model_gen_node3.go \
       "$dir"/model_platinum_properties2.go \
       "$dir"/model_p_edge2.go \
       2>/dev/null || true
}

function patch_swagger_license() {
  echo "patching swagger.license.json for known upstream issues"
  jq '
    # Fix parameter name case mismatches between path definitions and parameter names
    .paths["/job/disconnect/{jobId}/user/{userId}"].get.parameters[0].name = "jobId" |
    .paths["/customer/disconnect/{customerId}/job/{jobId}"].get.parameters[0].name = "customerId" |
    # Remove date-time format to generate plain string types (avoids timezone parsing issues)
    walk(if type == "object" and .type == "string" and .format == "date-time" then del(.format) else . end)
  ' swagger.license.json > swagger.license.patched.json
}

function generate_carbon_types() {
  echo "=== Generating types from Carbon OpenAPI spec ==="

  # 1. Fetch the OpenAPI spec from the running Carbon container
  echo "Fetching swagger.carbon.json from Carbon..."
  local max_retries=5
  local retry=0
  while [ $retry -lt $max_retries ]; do
    if curl -sf http://localhost:8090/openapi/v1.json -o swagger.carbon.json; then
      echo "Fetched swagger.carbon.json from Carbon"
      break
    fi
    retry=$((retry + 1))
    echo "Carbon not ready, retrying ($retry/$max_retries)..."
    sleep 2
  done
  if [ $retry -eq $max_retries ]; then
    echo "ERROR: Could not fetch swagger spec from Carbon at http://localhost:8090/openapi/v1.json"
    echo "Make sure Carbon is running (./stack devcompose up -d carbon)"
    return 1
  fi

  # 2. Patch the spec for known .NET 9 OpenAPI issues
  patch_swagger_carbon

  # 3. Remove only generated model files (preserves legacy_*.go and utils.go)
  echo "Removing generated model_*.go files..."
  find goapi/pkg/types/carbon -name 'model_*.go' -delete 2>/dev/null || true

  # 4. Generate Go types from the patched spec
  generate_types_go carbon

  # 5. Remove generated client.go (we don't use it)
  rm -f goapi/pkg/types/carbon/client.go

  sudo chown -R $USER:$USER goapi/pkg/types/carbon

  # 6. Simplify generated Go models (strip boilerplate, depointerize primitives)
  simplify_carbon_models

  # 7. Generate TypeScript types
  sudo rm -rf frontend/src/types/carbon
  generate_types_typescript carbon
  sudo chown -R $USER:$USER frontend/src/types/carbon

  # Note: Legacy types (SessionInfo, TableSpec, etc.) live in frontend/src/types/carbon-legacy/
  # and are NOT regenerated. They are pinned from the pre-consolidation Carbon API.

  echo "=== Carbon types generated ==="
  echo "Run 'cd goapi && go build ./...' and 'cd frontend && yarn tsc' to verify"
}

function generate_types() {
  # Generate Carbon types from running Carbon container
  generate_carbon_types

  # Generate License types from static swagger spec
  patch_swagger_license

  echo "removing existing license types"
  sudo rm -rf goapi/pkg/types/license
  sudo rm -rf frontend/src/types/license

  generate_types_go license
  generate_types_typescript license

  sudo chown -R $USER:$USER \
    frontend/src/types/license \
    goapi/pkg/types/license

  # Remove generated client.go files (we don't use them)
  rm -f goapi/pkg/types/license/client.go

  rm -f frontend/src/types/gotypes.ts

  # Generate Go type definitions for TypeScript
  (cd goapi/typescript && go run . -output $DIR/frontend/src/types/gotypes.ts)

  # Fix TypeScript type issues: 'int' is not a valid TS type, use 'number'
  sed -i 's/\[key: int\]/[key: number]/g' frontend/src/types/gotypes.ts

  # Clean up patched swagger files
  echo "cleaning up patched swagger files"
  rm -f swagger.carbon.patched.json swagger.license.patched.json
}

