function new_installation() {
  local name="$1" src="${3:-core-v1}"   # usage: new-installation <name> --from <parent>
  [[ -n "$name" ]] || { echo "usage: ./stack new-installation <name> --from <parent>"; return 1; }
  local dst="$DIR/installations/$name"
  [[ -e "$dst" ]] && { echo "installation '$name' already exists"; return 1; }
  [[ -f "$DIR/installations/$src/installation.json" ]] || { echo "parent installation '$src' not found"; return 1; }

  mkdir -p "$dst/overlay/.claude/skills"
  touch "$dst/overlay/.claude/skills/.keep"

  python3 - "$dst/installation.json" "$name" "$src" <<'PY'
import json, sys
p, name, parent = sys.argv[1], sys.argv[2], sys.argv[3]
json_str = json.dumps(
    {"name": name, "parent": parent, "description": "Derived from %s. Edit me." % parent},
    indent=2,
)
open(p, "w").write(json_str + "\n")
PY

  cat > "$dst/Dockerfile" <<EOF
# Derived Platinum installation — FROM the parent installation image.
#
# Inherits the parent's ENVIRONMENT (apt/pip/npm/pt/plugins) and KNOWLEDGE
# (skills, CLAUDE.md). Overrides are file-replacements via overlay/, whose layout
# mirrors /workspace (e.g. overlay/.claude/skills/<name>/, overlay/CLAUDE.md,
# overlay/lib/<helper>). Do NOT set CMD/ENTRYPOINT/EXPOSE/HEALTHCHECK — those are
# owned by the agentkit core image. Build via: ./stack rebuild sandbox $name
ARG BASE_IMAGE=registry:5000/platinum-sandbox-$src:dev
FROM \${BASE_IMAGE}
COPY installations/$name/overlay/ /workspace/

# The overlay can add/replace files but NOT delete inherited ones. To drop a file or
# package the parent ships, add an explicit RUN, e.g.:
#   RUN rm -rf /workspace/some-inherited-file && (npm uninstall -g some-pkg || true)
EOF

  echo "Created thin variant installations/$name (parent: $src)."
  echo "  Add overrides under installations/$name/overlay/ (mirrors /workspace), then:"
  echo "  ./stack rebuild sandbox $name"
}

function new-installation() {
  new_installation "$@"
}

