function ensure_dind_volume() {
  local vol_name="${ENV:-development}-dind-data"
  if ! docker volume inspect "$vol_name" &>/dev/null; then
    echo "Creating persistent DinD volume: $vol_name"
    docker volume create "$vol_name"
  fi
}

function compose() {
  docker compose -f docker-compose.yml "$@"
}

function devcompose() {
  docker compose -f docker-compose.yml -f docker-compose.dev.yml "$@"
}

function testcompose() {
  docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.test.yml "$@"
}

function start_test() {
  echo "=== Starting stack in test mode ==="
  ensure_dind_volume
  testcompose up -d

  echo "--- Waiting for GoAPI health ---"
  for i in $(seq 1 30); do
    if curl -sf http://localhost:8091/api/v1/health > /dev/null 2>&1; then
      echo "GoAPI healthy (attempt $i)"
      break
    fi
    if [ "$i" -eq 30 ]; then
      echo "ERROR: GoAPI not healthy after 30 attempts"
      testcompose logs goapi --tail=50
      exit 1
    fi
    sleep 2
  done

  echo "--- Waiting for frontend ---"
  for i in $(seq 1 20); do
    if curl -sf http://localhost:8091/ > /dev/null 2>&1; then
      echo "Frontend healthy (attempt $i)"
      break
    fi
    if [ "$i" -eq 20 ]; then
      echo "ERROR: Frontend not healthy"
      exit 1
    fi
    sleep 2
  done

  echo ""
  echo "=== Stack ready in test mode ==="
  echo "Run individual tests with:"
  echo "  cd e2e && yarn playwright test tests/12-alert-workflow.spec.ts --reporter=list"
  echo ""
  echo "Stop with: ./stack stop_test"
}

function stop_test() {
  echo "Stopping test stack..."
  testcompose down
}

function build() {
  devcompose build
}

function restart() {
  local service="${1-all}"
  shift
  # if the service is all, then we need to restart all the services
  if [[ "$service" == "all" ]]; then
    devcompose down
    devcompose up -d
  else
    # Use stop + up instead of restart so compose file and env var changes are picked up
    devcompose stop $service
    devcompose up -d $service

    # sandbox-proxy shares dind's network namespace (network_mode: "service:dind").
    # When dind restarts, its network dies — so we must restart it too.
    if [[ "$service" == "dind" ]]; then
      echo "dind restarted — cascading restart to sandbox-proxy (shared network namespace)..."
      devcompose stop sandbox-proxy
      devcompose up -d sandbox-proxy
    fi
  fi
}

function rebuild() {
  local service="${1-all}"
  shift
  # if the service is all, then we need to restart all the services
  if [[ "$service" == "all" ]]; then
    devcompose down
    devcompose build
    devcompose up -d
  elif [[ "$service" == "sandbox" || "$service" == "sandbox-agentkit" ]]; then
    # Agent sandbox image, built host-side as a FROM chain:
    #   core: agent-library/sandbox/Dockerfile  → agentkit-sandbox:dev
    #   app:  installations/<name>/Dockerfile    → platinum-sandbox-<name>:dev
    # Both dev and prod push to a registry. Local dev uses registry:5000 with the
    # :dev tag (force-pulled per session); prod pushes to ACR and records a digest.
    local base="agentkit-sandbox:dev"

    # Parse flags: --plan (print order, don't build), --no-deps (skip ancestors),
    # --acr (push to the remote ACR), --local (push to registry:5000, the default).
    local plan_only="" no_deps="" use_acr=""
    local rest=()
    for a in "$@"; do
      case "$a" in
        --plan) plan_only=1 ;;
        --no-deps) no_deps=1 ;;
        --acr) use_acr=1 ;;
        --local) use_acr="" ;;
        *) rest+=("$a") ;;
      esac
    done
    name="${rest[0]:-core-v1}"

    # Registry selection is decoupled from the runtime AGENT_V2_REGISTRY_URL (which
    # may be ACR in a server-shaped .env). Host-side sandbox builds default to the
    # local registry:5000 — the safe choice for dev iteration — so a routine
    # rebuild can never accidentally push a locally-built image to production ACR
    # or overwrite a committed digest. `--acr` (used by `./stack release`) opts in.
    local reg="registry:5000"
    if [[ -n "$use_acr" ]]; then
      [[ -z "${AGENT_V2_REGISTRY_URL:-}" && -f "$DIR/.env" ]] && { set -a; source "$DIR/.env"; set +a; }
      reg="${AGENT_V2_REGISTRY_URL:-}"
      if [[ -z "$reg" ]] || installations_is_local_registry "$reg"; then
        echo "ERROR: --acr requires AGENT_V2_REGISTRY_URL to be a remote registry (got '${reg:-unset}')" >&2
        echo "       Set the ACR url + creds in .env, e.g. AGENT_V2_REGISTRY_URL=platinumimages.azurecr.io" >&2
        return 1
      fi
    fi

    local nodes; nodes="$(installation_nodes_json)"
    local order
    if [[ "$name" == "all" ]]; then
      order="$(cd "$DIR/agent-library/go" && echo "$nodes" | go run ./cmd/imagetree)" || return 1
    elif [[ -n "$no_deps" ]]; then
      order="$name"
    else
      order="$(cd "$DIR/agent-library/go" && echo "$nodes" | go run ./cmd/imagetree -target "$name")" || return 1
    fi

    if [[ -n "$plan_only" ]]; then
      echo "Build plan (registry ${reg}):"
      while read -r n; do [[ -n "$n" ]] && echo "  $n  FROM  $(resolve_base_ref "$n" "$reg")"; done <<< "$order"
      return 0
    fi

    # Roots need the agentkit core image present first.
    echo "Building ${base} (core)..."
    docker build -t "$base" "$DIR/agent-library/sandbox" || { echo "core build failed"; return 1; }
    if installations_is_local_registry "$reg"; then ensure_registry_host "$reg"; else acr-login; fi

    while read -r n; do
      [[ -n "$n" ]] || continue
      build_one_installation "$n" "$reg" || return 1
    done <<< "$order"
    echo "Done (${name}). $(installations_is_local_registry "$reg" && echo 'New sessions force-pull the :dev tag.' || echo "Commit installations/*/installation.json.")"
  else
    devcompose stop $service
    devcompose build $service
    devcompose up -d $service
  fi
}

function installations_is_local_registry() {
  case "$1" in
    registry:5000|localhost:5000|127.0.0.1:5000) return 0 ;;
    *) return 1 ;;
  esac
}

# The local sandbox images are tagged registry:5000/... so that DinD can pull
# them by that name from inside the Docker network. The host-side `docker push`
# therefore also needs `registry` to resolve — but it's only a Compose service
# name. Map it to loopback in /etc/hosts. This is easy to forget (and WSL2
# regenerates /etc/hosts on restart unless generateHosts=false in /etc/wsl.conf),
# so check on every local sandbox rebuild and add it if missing.
function ensure_registry_host() {
  local reg="$1"
  local host="${reg%:*}"
  # Nothing to do for loopback-by-name registries.
  case "$host" in localhost|127.0.0.1) return 0 ;; esac
  # Already resolves? (getent covers /etc/hosts + DNS.)
  if getent hosts "$host" >/dev/null 2>&1; then return 0; fi
  echo "Registry hostname '$host' does not resolve on this machine."
  echo "Adding '127.0.0.1 $host' to /etc/hosts (requires sudo)..."
  if printf '127.0.0.1\t%s\n' "$host" | sudo tee -a /etc/hosts >/dev/null; then
    echo "Added. ('$host' now maps to loopback.)"
  else
    echo "Could not update /etc/hosts automatically. Add this line manually:"
    echo "    127.0.0.1 $host"
    return 1
  fi
}

# Emit a JSON array of {name,parent} for every installation, for imagetree.
function installation_nodes_json() {
  python3 - "$DIR/installations" <<'PY'
import json, os, sys, glob
root = sys.argv[1]
out = []
for p in sorted(glob.glob(os.path.join(root, "*", "installation.json"))):
    d = json.load(open(p))
    out.append({"name": d["name"], "parent": d.get("parent", "")})
print(json.dumps(out))
PY
}

# Read one installation's parent name ("" if root).
function installation_parent() {
  python3 -c 'import json,sys;print(json.load(open(sys.argv[1])).get("parent",""))' \
    "$DIR/installations/$1/installation.json"
}

# Resolve the BASE_IMAGE build-arg for an installation.
#   no parent      -> the agentkit core image (agentkit-sandbox:dev)
#   parent, dev    -> <reg>/platinum-sandbox-<parent>:dev
#   parent, prod   -> <reg>/platinum-sandbox-<parent>@<digest from parent installation.json>
function resolve_base_ref() {
  local name="$1" reg="$2" parent
  parent="$(installation_parent "$name")"
  if [[ -z "$parent" ]]; then
    echo "agentkit-sandbox:dev"
    return 0
  fi
  if installations_is_local_registry "$reg"; then
    echo "${reg}/platinum-sandbox-${parent}:dev"
  else
    local digest
    digest="$(python3 -c 'import json,sys;print(json.load(open(sys.argv[1])).get("image",{}).get("digest",""))' \
      "$DIR/installations/${parent}/installation.json")"
    [[ -n "$digest" ]] || { echo "ERROR: parent '${parent}' has no recorded digest; build it first" >&2; return 1; }
    echo "${reg}/platinum-sandbox-${parent}@${digest}"
  fi
}

# Fail if a derived Dockerfile redefines the core's runtime contract.
function assert_runtime_contract() {
  local df="$1"
  if grep -qE '^[[:space:]]*(CMD|ENTRYPOINT|EXPOSE|HEALTHCHECK)\b' "$df"; then
    echo "ERROR: $df sets CMD/ENTRYPOINT/EXPOSE/HEALTHCHECK — owned by the agentkit core image" >&2
    return 1
  fi
  return 0
}

# Build + push a single installation against its resolved parent.
function build_one_installation() {
  local name="$1" reg="$2"
  local dir="$DIR/installations/$name"
  [[ -f "$dir/Dockerfile" ]] || { echo "no installation '$name' at $dir" >&2; return 1; }
  assert_runtime_contract "$dir/Dockerfile" || return 1
  local base; base="$(resolve_base_ref "$name" "$reg")" || return 1
  local image="${reg}/platinum-sandbox-${name}:dev"
  echo "[build] ${name}  FROM ${base}  ->  ${image}"
  local tags=(-t "$image")
  [[ "$name" == "core-v1" ]] && tags+=(-t "${reg}/platinum-sandbox-agentkit:dev")  # legacy alias
  docker build -f "$dir/Dockerfile" --build-arg "BASE_IMAGE=${base}" "${tags[@]}" "$DIR" \
    || { echo "build failed: $name" >&2; return 1; }
  docker push "$image"
  [[ "$name" == "core-v1" ]] && docker push "${reg}/platinum-sandbox-agentkit:dev"
  if ! installations_is_local_registry "$reg"; then
    record_installation_digest "$name" "$image"
  fi
}

function record_installation_digest() {
  # Capture the pushed manifest digest and write it into installation.json so the
  # hash lives in the repo (committed). Regenerate the embedded goapi manifest.
  local name="$1" image="$2"
  local registry="${image%:*}"           # strip ":dev" -> repo path
  local digest
  digest="$(docker inspect --format '{{index .RepoDigests 0}}' "$image" 2>/dev/null | sed 's/.*@//')"
  [[ -n "$digest" ]] || { echo "WARN: could not read digest for $image"; return 0; }
  local commit; commit="$(git -C "$DIR" rev-parse --short HEAD)"
  local parent base_digest=""
  parent="$(installation_parent "$name")"
  if [[ -n "$parent" ]]; then
    base_digest="$(python3 -c 'import json,sys;print(json.load(open(sys.argv[1])).get("image",{}).get("digest",""))' \
      "$DIR/installations/${parent}/installation.json")"
  fi
  python3 "$DIR/scripts/build-installations-manifest.py" \
    --set-image "$name" "$registry" "$digest" "$commit" "$base_digest"
  echo "Recorded ${name} digest ${digest}${base_digest:+ (base ${base_digest})} into installation.json"
}

function acr-login() {
  # Host docker login to the ACR (needed only for PUSHING images). The pull side
  # needs no host login — goapi reads AGENT_V2_REGISTRY_* from config and hands DinD
  # per-pull auth directly. Here we reuse those same admin creds for the host
  # `docker login` (self-contained — no `az`/Azure-AD session required).
  #
  # Load creds from .env if they aren't already exported in the shell (the stack
  # script doesn't source .env globally — only build_images does).
  if [[ -z "${AGENT_V2_REGISTRY_USERNAME:-}" && -f "$DIR/.env" ]]; then
    set -a; source "$DIR/.env"; set +a
  fi
  if [[ -n "${AGENT_V2_REGISTRY_USERNAME:-}" && -n "${AGENT_V2_REGISTRY_PASSWORD:-}" ]]; then
    echo "${AGENT_V2_REGISTRY_PASSWORD}" | docker login "${AGENT_V2_REGISTRY_URL:-platinumimages.azurecr.io}" \
      -u "${AGENT_V2_REGISTRY_USERNAME}" --password-stdin
  else
    echo "AGENT_V2_REGISTRY_USERNAME/PASSWORD not set in env or .env — falling back to az acr login"
    az acr login --name platinumimages
  fi
}

# sandbox_status — report which agent installation (sandbox) images are present in
# the local registry, and print the exact command to build any that are missing.
# Images are pushed to registry:5000 (local) or ACR (prod); DinD force-pulls the
# :dev tag on each new session. Shown automatically by `start` (in a tmux pane).
function sandbox_status() {
  local reg_container="platinum-${ENV:-development}-registry"
  # This status check only ever inspects the local dev registry container, so the
  # label is always registry:5000 regardless of the (possibly ACR) runtime
  # AGENT_V2_REGISTRY_URL in .env. ACR images are pinned by digest via `release`.
  local reg="registry:5000"
  # Wait briefly for the registry to answer.
  local ready=0 i
  for i in $(seq 1 15); do
    if docker exec "$reg_container" wget -qO- "http://localhost:5000/v2/_catalog" &>/dev/null; then ready=1; break; fi
    sleep 1
  done
  local catalog=""
  [[ "$ready" == 1 ]] && catalog="$(docker exec "$reg_container" wget -qO- "http://localhost:5000/v2/_catalog" 2>/dev/null)"

  local missing=() present=() n repo inst
  for inst in "$DIR"/installations/*/; do
    [[ -f "${inst}Dockerfile" ]] || continue
    n="$(basename "$inst")"
    repo="platinum-sandbox-${n}"
    if [[ "$catalog" == *"\"${repo}\""* ]]; then present+=("$n"); else missing+=("$n"); fi
  done

  local R="\033[0m" RED_BANNER="\033[1;97;41m" GRN_BANNER="\033[1;30;42m" YEL="\033[1;33m" GRN="\033[32m" REDX="\033[31m"
  echo
  if [[ ${#missing[@]} -gt 0 ]]; then
    printf "${RED_BANNER}                                                                  ${R}\n"
    printf "${RED_BANNER}   ⚠  SANDBOX IMAGES NOT IN REGISTRY — THE AGENT WILL NOT WORK    ${R}\n"
    printf "${RED_BANNER}                                                                  ${R}\n"
    printf "${RED_BANNER}   Build + push them now:                                          ${R}\n"
    printf "${RED_BANNER}       ./stack rebuild sandbox all                                ${R}\n"
    printf "${RED_BANNER}                                                                  ${R}\n"
  else
    printf "${GRN_BANNER}   ✓  All sandbox installation images are built and pushed        ${R}\n"
  fi
  echo
  echo "Agent installation (sandbox) images — pushed to registry (${reg}); DinD force-pulls the :dev tag on each new session."
  for n in "${present[@]}"; do printf "  ${GRN}✓${R} %-10s in registry\n" "$n"; done
  for n in "${missing[@]}"; do printf "  ${REDX}✗${R} %-10s missing  ->  ./stack rebuild sandbox %s\n" "$n" "$n"; done
  echo
  echo   "  Rebuild an installation image:  ./stack rebuild sandbox <name>   (pushes to ${reg})"
  echo   "  Rebuild all installations:      ./stack rebuild sandbox all"
  if [[ ${#missing[@]} -gt 0 ]]; then
    printf "  ${YEL}Then restart goapi to pick up config:${R}  ./stack rebuild goapi\n"
  fi
}

function start() {
  if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
    echo "Session $TMUX_SESSION already exists. Attaching..."
    sleep 1
    tmux -2 attach -t $TMUX_SESSION
    exit 0;
  fi

  export MANUALRUN=1
  export LOG_LEVEL=debug

  echo "Starting docker compose"

  ensure_dind_volume
  # Brings up everything in docker-compose.yml + .dev.yml, including the local
  # registry:2 (snapshot push/pull target — ACR stand-in for dev/test). The dind
  # image (with dind/daemon.json's insecure-registry config) is built by
  # `./stack build`; run that first if you've changed the Dockerfile.
  devcompose up -d

  echo
  echo ">> Reminder: agent installation (sandbox) images are NOT built by 'start'."
  echo ">> If the agent can't launch sessions, build them:  ./stack rebuild sandbox all"
  echo ">> Live status is shown in the bottom-left tmux pane ('sandbox images')."
  echo

  echo "Creating tmux session $TMUX_SESSION..."

  # get the size of the window and create a session at that size
  # Use defaults if stty fails (e.g., in non-interactive contexts)
  local screensize=$(stty size 2>/dev/null || echo "50 200")
  local width=$(echo -n "$screensize" | awk '{print $2}')
  local height=$(echo -n "$screensize" | awk '{print $1}')
  width=${width:-200}
  height=${height:-50}
  tmux -2 new-session -d -s $TMUX_SESSION -x "$width" -y "$(($height - 1))"

  # Create 5 panes (split 4 times from pane 0)
  for i in $(seq 1 5); do
    tmux split-window -v -t $TMUX_SESSION
    tmux select-layout -t $TMUX_SESSION even-vertical
  done

  # Service logs in all 5 panes
  tmux send-keys -t 0 './stack devcompose logs -f goapi goworker' C-m
  tmux send-keys -t 1 './stack devcompose logs -f carbon' C-m
  tmux send-keys -t 2 './stack devcompose logs -f dind sandbox-proxy registry' C-m
  # Persistent, prominent reminder of which installation images are built / missing.
  tmux send-keys -t 3 'clear; ./stack sandbox_status' C-m
  # Give the reminder pane room so the banner isn't clipped, and focus it on attach.
  tmux resize-pane -t 3 -y 16 2>/dev/null || true
  tmux select-pane -t 3 2>/dev/null || true

  tmux -2 attach-session -t $TMUX_SESSION
}

function stop() {
  echo "Removing docker containers"
  devcompose down
  echo "Stopping tmux session $TMUX_SESSION..."
  tmux kill-session -t $TMUX_SESSION ||true
}

function db() {
  local subcommand="${1-cli}"
  shift
  local containername="${1-postgres}"
  shift
  if [[ "$subcommand" == "cli" ]]; then
    docker compose exec $containername psql --user postgres "$@"
