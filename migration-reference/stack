function migrate_pg() {
  local environment="${1:-development}"

  if [[ "$environment" != "development" && "$environment" != "staging" && "$environment" != "production" ]]; then
    echo "Error: Invalid environment '$environment'"
    echo "Valid environments: development, staging, production"
    echo "Usage: ./stack migrate_pg [development|staging|production]"
    exit 1
  fi

  local old_volume="${environment}-postgres-db"
  local new_volume="${environment}-postgres-db-pg16"

  echo "================================================"
  echo "POSTGRESQL 12 → 16 MIGRATION"
  echo "================================================"
  echo "Environment:  $environment"
  echo "Old volume:   $old_volume (PG 12, kept as backup)"
  echo "New volume:   $new_volume (PG 16)"
  if [[ "$environment" != "development" ]]; then
    echo "Remote Host:  $DEPLOY_HOST"
  fi
  echo ""
  echo "This will:"
  echo "  1. Dump all data from the PG 12 volume"
  echo "  2. Start PG 16 on a new volume"
  echo "  3. Restore the dump into PG 16"
  echo ""
  echo "The old volume is kept intact as a backup."
  echo "================================================"
  read -p "Proceed? [y/N] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Migration cancelled"
    exit 0
  fi

  if [[ "$environment" == "development" ]]; then
    _migrate_pg_local "$old_volume"
  else
    _migrate_pg_remote "$environment" "$old_volume"
  fi
}

function _migrate_pg_local() {
  local old_volume="$1"
  local dump_file="/tmp/pg12_dump_$(date +%s).sql"

  echo ""
  echo "=== Step 1/4: Stopping services ==="
  devcompose down

  echo ""
  echo "=== Step 2/4: Dumping PG 12 data ==="
  echo "Starting temporary PG 12 container from volume $old_volume..."
  docker run -d --name pg12_migrate_tmp \
    -v "${old_volume}:/var/lib/postgresql/data" \
    postgres:12.13-alpine

  echo "Waiting for PG 12 to be ready..."
  local retries=30
  while ! docker exec pg12_migrate_tmp pg_isready -U postgres >/dev/null 2>&1; do
    retries=$((retries - 1))
    if [[ $retries -le 0 ]]; then
      echo "Error: PG 12 did not become ready"
      docker logs pg12_migrate_tmp
      docker rm -f pg12_migrate_tmp
      exit 1
    fi
    sleep 1
  done

  echo "Running pg_dumpall..."
  docker exec pg12_migrate_tmp pg_dumpall -U postgres > "$dump_file"

  echo "Stopping temporary PG 12 container..."
  docker rm -f pg12_migrate_tmp

  local dump_size
  dump_size=$(du -h "$dump_file" | cut -f1)
  echo "Dump complete: $dump_file ($dump_size)"

  echo ""
  echo "=== Step 3/4: Starting PG 16 (new volume) ==="
  devcompose up -d postgres
  echo "Waiting for PG 16 to be ready..."
  sleep 3
  local pg16_retries=30
  while ! devcompose exec -T postgres pg_isready -U postgres >/dev/null 2>&1; do
    pg16_retries=$((pg16_retries - 1))
    if [[ $pg16_retries -le 0 ]]; then
      echo "Error: PG 16 did not become ready"
      exit 1
    fi
    sleep 1
  done
  echo "PG 16 is ready"

  echo ""
  echo "=== Step 4/4: Restoring dump into PG 16 ==="
  echo "Note: Warnings about 'role postgres already exists' are expected."
  devcompose exec -T postgres psql -U postgres < "$dump_file" || true

  # The PG 12 dump contains md5-hashed passwords which PG 16 (scram-sha-256) can't verify.
  # Reset the postgres password using the same env var that docker-compose passes to services.
  echo ""
  echo "Resetting postgres password (md5 → scram-sha-256)..."
  local pg_password="${POSTGRES_ADMIN_PASSWORD:-postgres}"
  devcompose exec -T postgres psql -U postgres -c "ALTER ROLE postgres WITH PASSWORD '${pg_password}';"

  echo ""
  echo "Cleaning up dump file..."
  rm -f "$dump_file"

  echo ""
  echo "Starting all services..."
  devcompose up -d

  echo ""
  echo "================================================"
  echo "Migration complete!"
  echo "Old volume '$old_volume' is still available as backup."
  echo ""
  echo "Verify with:"
  echo "  echo 'SELECT version();' | ./stack psql_pipe"
  echo "  echo 'SELECT name FROM go_schema_migrations ORDER BY name;' | ./stack psql_pipe"
  echo ""
  echo "Once verified, you can remove the old volume with:"
  echo "  docker volume rm $old_volume"
  echo "================================================"
}

function _migrate_pg_remote() {
  local environment="$1"
  local old_volume="$2"
  local dump_path="/tmp/pg12_dump_${environment}.sql"

  echo ""
  echo "=== Running migration on $DEPLOY_HOST for $environment ==="

  ssh $DEPLOY_HOST <<EOF
set -euo pipefail
cd Platinum

echo ""
echo "=== Step 1/4: Stopping services ==="
docker compose -p $environment down

echo ""
echo "=== Step 2/4: Dumping PG 12 data ==="
echo "Starting temporary PG 12 container from volume $old_volume..."
docker run -d --name pg12_migrate_tmp \
  -v "${old_volume}:/var/lib/postgresql/data" \
  postgres:12.13-alpine

echo "Waiting for PG 12 to be ready..."
RETRIES=30
while ! docker exec pg12_migrate_tmp pg_isready -U postgres >/dev/null 2>&1; do
  RETRIES=\$((RETRIES - 1))
  if [ \$RETRIES -le 0 ]; then
    echo "Error: PG 12 did not become ready"
    docker logs pg12_migrate_tmp
    docker rm -f pg12_migrate_tmp
    exit 1
  fi
  sleep 1
done

echo "Running pg_dumpall..."
docker exec pg12_migrate_tmp pg_dumpall -U postgres > "$dump_path"

echo "Stopping temporary PG 12 container..."
docker rm -f pg12_migrate_tmp

DUMP_SIZE=\$(du -h "$dump_path" | cut -f1)
echo "Dump complete: $dump_path (\$DUMP_SIZE)"

echo ""
echo "=== Step 3/4: Starting PG 16 (new volume) ==="
docker compose -p $environment up -d postgres
echo "Waiting for PG 16 to be ready..."
sleep 3
RETRIES=30
PG_CONTAINER="platinum-${environment}-postgres"
while ! docker exec "\$PG_CONTAINER" pg_isready -U postgres >/dev/null 2>&1; do
  RETRIES=\$((RETRIES - 1))
  if [ \$RETRIES -le 0 ]; then
    echo "Error: PG 16 did not become ready"
    exit 1
  fi
  sleep 1
done
echo "PG 16 is ready"

echo ""
echo "=== Step 4/4: Restoring dump into PG 16 ==="
echo "Note: Warnings about 'role postgres already exists' are expected."
docker exec -i "\$PG_CONTAINER" psql -U postgres < "$dump_path" || true

# The PG 12 dump contains md5-hashed passwords which PG 16 (scram-sha-256) can't verify.
# Reset the postgres password to match what docker-compose passes to services.
echo ""
echo "Resetting postgres password (md5 → scram-sha-256)..."
docker exec "\$PG_CONTAINER" psql -U postgres -c "ALTER ROLE postgres WITH PASSWORD '\${POSTGRES_ADMIN_PASSWORD:-postgres}';"

echo ""
echo "Cleaning up dump file..."
rm -f "$dump_path"

echo ""
echo "Starting all services..."
docker volume create ${environment}-dind-data 2>/dev/null || true
docker compose -p $environment up -d

echo ""
echo "================================================"
echo "Migration complete for $environment!"
echo "Old volume '$old_volume' is still available as backup."
echo ""
echo "Once verified, you can remove the old volume with:"
echo "  docker volume rm $old_volume"
echo "================================================"
EOF

  local exit_code=$?
  if [[ $exit_code -eq 0 ]]; then
    echo ""
    echo "================================================"
    echo "Remote migration for $environment completed!"
    echo ""
    echo "Verify with:"
    echo "  ssh $DEPLOY_HOST \"docker exec platinum-${environment}-postgres psql -U postgres -c 'SELECT version();'\""
    echo "================================================"
  else
    echo ""
    echo "================================================"
    echo "Migration for $environment failed with exit code $exit_code"
    echo "The dump file may still be at $dump_path on the server."
    echo "================================================"
    exit $exit_code
  fi
}

