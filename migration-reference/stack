function test_ci() {
  echo "=== CI Test Suite ==="
  echo ""

  local e2e_mode="${CI_E2E_MODE:-all}"  # all | fast | sandbox

  # 1. Start stack in detached mode with test overlay
  echo "--- Starting services ---"
  ensure_dind_volume
  docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.test.yml up -d

  # 2. Wait for GoAPI health
  echo "--- Waiting for GoAPI health ---"
  local max_attempts=30
  for i in $(seq 1 $max_attempts); do
    if curl -sf http://localhost:8091/api/v1/health > /dev/null 2>&1; then
      echo "GoAPI healthy (attempt $i)"
      break
    fi
    if [ "$i" -eq "$max_attempts" ]; then
      echo "ERROR: GoAPI not healthy after $max_attempts attempts"
      docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.test.yml logs goapi --tail=50
      exit 1
    fi
    sleep 2
  done

  # 3. Wait for frontend (via router proxy)
  echo "--- Waiting for frontend ---"
  for i in $(seq 1 20); do
    if curl -sf http://localhost:8091/ > /dev/null 2>&1; then
      echo "Frontend healthy (attempt $i)"
      break
    fi
    if [ "$i" -eq 20 ]; then
      echo "ERROR: Frontend not healthy"
      exit 1
    fi
    sleep 2
  done

  # 4. Run E2E tests
  echo ""
  echo "--- E2E tests (mode: $e2e_mode) ---"
  cd "$DIR/e2e"
  local e2e_exit=0
  case "$e2e_mode" in
    fast)    yarn test:fast || e2e_exit=$? ;;
    sandbox) yarn test:sandbox || e2e_exit=$? ;;
    *)       yarn test || e2e_exit=$? ;;
  esac

  # 5. Collect logs on failure
  if [ $e2e_exit -ne 0 ]; then
    echo ""
    echo "--- E2E FAILED — collecting service logs ---"
    docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.test.yml \
      logs --since=10m goapi dind > "$DIR/e2e/ci-logs.txt" 2>&1
    echo "Logs saved to e2e/ci-logs.txt"
  fi

  # 6. Tear down (unless CI_KEEP_STACK=true)
  if [ "${CI_KEEP_STACK:-}" != "true" ]; then
    echo ""
    echo "--- Tearing down ---"
    docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.test.yml down
  fi

  echo ""
  if [ $e2e_exit -eq 0 ]; then
    echo "=== CI Suite PASSED ==="
  else
    echo "=== CI Suite FAILED ==="
    exit $e2e_exit
  fi
}

