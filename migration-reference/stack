# ── Canonical 3-tier test runners (mirror CI 1:1) ──────────────────────────────
# Run any one tier locally with a single command. Each is the SAME thing the CI
# job of the same name runs, so green locally == green in CI.
#   ./stack tests-unit          — fast, no Docker, no stack
#   ./stack tests-integration   — real Docker + scripted mock model (no stack/creds)
#   ./stack tests-e2e [sandbox] — browser e2e against a running ./stack dev

# Tier 0 — every CI unit job, in sequence. No Docker, no stack.
function tests-unit() {
  echo "=== Unit tests (Tier 0 — no Docker, no stack) ==="
  ( cd "$DIR"                           && go test ./goapi/... -count=1 )        || return 1
  ( cd "$DIR/agent-library/go"          && go test ./... -count=1 )              || return 1
  ( cd "$DIR/frontend"                  && yarn tsc && yarn test )               || return 1
  ( cd "$DIR/agent-library/web"         && yarn test )                           || return 1
  ( cd "$DIR/agent-library/sandbox"     && yarn test )                           || return 1
  ( cd "$DIR/agent-library/mock-server" && yarn test )                           || return 1
  ( cd "$DIR/installations/core-v1"      && yarn test )                           || return 1
  echo "=== Unit tests passed ==="
}

# Tier 1 — deterministic integration. Real Docker containers + scripted mock model
# + mock Carbon; no compose stack, no model creds. Verbose (-v) so you can SEE each
# test execute (and spot any SKIP). Needs the sandbox image built.
function tests-integration() {
  echo "=== Integration tests (Tier 1 — real Docker, scripted mock model) ==="
  if ! docker info > /dev/null 2>&1; then
    echo "ERROR: Docker daemon not available — integration tests need it."; return 1
  fi
  if ! docker image inspect platinum-sandbox-agentkit:dev > /dev/null 2>&1; then
    echo "ERROR: image 'platinum-sandbox-agentkit:dev' not found."
    echo "       Build it first:  ./stack rebuild sandbox core-v1"
    echo "       (core-v1 is automatically also tagged as platinum-sandbox-agentkit:dev)"
    return 1
  fi
  echo "--- agentkit-systemtest (real containers) ---"
  ( cd "$DIR/agent-library/go" && go test -tags integration -v ./systemtest/ -count=1 -timeout 1200s ) || return 1
  echo "--- agentdet (in-process backend + real sandbox) ---"
  ( cd "$DIR/goapi" && AGENTDET=1 go test -tags agentdet -v ./integration/agent/ -count=1 -timeout 1800s ) || return 1
  # NOTE: agent-library/e2e (the agentkit library's reference chat-UI e2e) is
  # intentionally NOT run here — it spawns its own web/mock servers on fixed ports
  # that collide with a running ./stack dev, and it targets the agentkit standalone
  # stack, not Platinum. It runs in the agentkit repo's own CI.
  echo "=== Integration tests passed ==="
}

# Tier 2 — browser e2e against a RUNNING dev stack. `fast` (default, non-sandbox)
# or `sandbox` (real model — needs DinD + PLATINUM_AZURE_CLAUDE_* creds).
function tests-e2e() {
  local mode="${1:-fast}"
  echo "=== E2E tests (mode: $mode — requires ./stack dev to be running) ==="
  if ! curl -sf http://localhost:8091/api/v1/health > /dev/null 2>&1; then
    echo "ERROR: dev stack not reachable at http://localhost:8091 — start it with  ./stack dev"
    return 1
  fi
  case "$mode" in
    fast)
      ( cd "$DIR/e2e" && yarn test:fast ) || return 1
      ( cd "$DIR/system-tools" && yarn test-sse ) || return 1
      ;;
    sandbox)
      ( cd "$DIR/e2e" && yarn test:sandbox ) || return 1
      ;;
    *)
      echo "Unknown mode '$mode' (use: fast | sandbox)"; return 1 ;;
  esac
  echo "=== E2E tests ($mode) passed ==="
}

